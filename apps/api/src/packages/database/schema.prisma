generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Agency ────────────────────────────────────────────────────────────────────
model Agency {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  slug             String    @unique          // used for xyz.funtush.io
  tier             String    @default("FREE") // FREE | STARTER | PRO | ENTERPRISE
  status           String    @default("ACTIVE") // ACTIVE | SUSPENDED | LOCKED
  statusReason     String?
  statusUpdatedAt  DateTime?
  country          String?
  tenantId         String    @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  domainMappings   DomainMapping[]
  subscription     Subscription?
  settings         AgencySettings?
  bookings         Booking[]
  treks            Trek[]
  invoices         Invoice[]
  breakGlassTokens BreakGlassToken[]
}

// ── DomainMapping (custom domains) ───────────────────────────────────────────
model DomainMapping {
  id        String   @id @default(cuid())
  domain    String   @unique             // e.g. www.custom.com
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  createdAt DateTime @default(now())
}

// ── Subscription ──────────────────────────────────────────────────────────────
model Subscription {
  id        String   @id @default(cuid())
  agencyId  String   @unique
  agency    Agency   @relation(fields: [agencyId], references: [id])
  status    String   // ACTIVE | CANCELLED | PAST_DUE
  plan      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── AgencySettings ────────────────────────────────────────────────────────────
model AgencySettings {
  id        String @id @default(cuid())
  agencyId  String @unique
  agency    Agency @relation(fields: [agencyId], references: [id])
  data      Json   @default("{}")
}

// ── Booking ───────────────────────────────────────────────────────────────────
model Booking {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id])
  totalAmount Decimal  @default(0)
  createdAt   DateTime @default(now())
}

// ── Trek ──────────────────────────────────────────────────────────────────────
model Trek {
  id       String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id])
  status   String // DRAFT | LIVE | ARCHIVED
}

// ── Invoice ───────────────────────────────────────────────────────────────────
model Invoice {
  id       String   @id @default(cuid())
  agencyId String
  agency   Agency   @relation(fields: [agencyId], references: [id])
  amount   Decimal
  status   String   // PENDING | PAID | FAILED
  paidAt   DateTime?
}

// ── BreakGlassToken ───────────────────────────────────────────────────────────
model BreakGlassToken {
  id          String   @id @default(cuid())
  token       String   @unique
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id])
  issuedByIp  String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
}
