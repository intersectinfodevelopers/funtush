{
  "name": "@funtush/api",
  "version": "0.0.0",
  "private": true,
  "description": "Funtush backend API (Node.js + Express).",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .turbo coverage"
  },
  "dependencies": {
    "@funtush/database": "workspace:*",
    "@funtush/shared": "workspace:*",
    "express": "^4.21.2",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^8.0.0"
  }
}
