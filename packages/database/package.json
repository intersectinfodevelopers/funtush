{
  "name": "@funtush/database",
  "version": "0.0.0",
  "private": true,
  "description": "Data-access layer (PostgreSQL/MongoDB/Redis) for Funtush.",
  "type": "module",
  "main": "./src/index.js",
  "exports": { ".": "./src/index.js" },
  "scripts": {
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf .turbo coverage",
